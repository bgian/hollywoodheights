NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity token with write access (used to persist rotating Constant Contact OAuth tokens)
SANITY_API_WRITE_TOKEN=

# Constant Contact (https://app.constantcontact.com/pages/dma/portal/)
CONSTANT_CONTACT_CLIENT_ID=
CONSTANT_CONTACT_CLIENT_SECRET=
